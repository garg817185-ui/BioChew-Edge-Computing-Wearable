// Helper to log in a verified Google user account
function loginGoogleUser(email, name) {
    const usersDb = JSON.parse(localStorage.getItem('biochew_users_db') || '[]');
    let existing = usersDb.find(u => u.email && u.email.toLowerCase() === email.toLowerCase());

    if (!existing) {
        // Create new account entry
        existing = {
            name: name,
            email: email.toLowerCase(),
            phone: 'Google Account',
            password: 'google_provider_stub',
            photo: null,
            provider: 'google',
            health: {},
            history: [],
            notes: []
        };
        usersDb.push(existing);
        localStorage.setItem('biochew_users_db', JSON.stringify(usersDb));
    }

    // Sign in active session
    localStorage.setItem('biochew_user', JSON.stringify(existing));
    localStorage.setItem('biochew_session_history', JSON.stringify(existing.history || []));
    localStorage.setItem('biochew_session_notes', JSON.stringify(existing.notes || []));

    closeGoogleModal();
    toast(`Welcome, ${existing.name}! Signed in with Google.`, 'success');
    setTimeout(() => {
        window.location.href = 'index.html';
    }, 1500);
}

// Bind clicks to pre-seeded Google accounts
document.querySelectorAll('.google-account-item').forEach(item => {
    item.addEventListener('click', function() {
        const email = this.dataset.email;
        const name = this.dataset.name;
        loginGoogleUser(email, name);
    });
});

// Custom Google Account submission
googleCustomSubmit.addEventListener('click', function() {
    const emailVal = googleCustomEmail.value.trim();
    const nameVal = googleCustomName.value.trim() || 'Google User';

    if (!emailVal) {
        toast('Gmail address is required.', 'error');
        googleCustomEmail.focus();
        return;
    }
    if (!isValidEmail(emailVal)) {
        toast('Please enter a valid email address.', 'error');
        googleCustomEmail.focus();
